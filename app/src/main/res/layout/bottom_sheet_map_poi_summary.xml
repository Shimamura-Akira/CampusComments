<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:minHeight="300dp"
    app:behavior_hideable="true"
    app:behavior_peekHeight="0dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainer"
    app:cardCornerRadius="@dimen/corner_xl"
    app:cardElevation="8dp"
    app:layout_behavior="@string/bottom_sheet_behavior"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/space_page"
        android:paddingTop="@dimen/space_smd"
        android:paddingEnd="@dimen/space_page"
        android:paddingBottom="@dimen/space_lg">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_sheet_handle" />

        <TextView
            android:id="@+id/summaryTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:textAppearance="@style/TextAppearance.Campus.Headline" />

        <TextView
            android:id="@+id/summaryTypeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:background="@drawable/bg_chip_secondary"
            android:paddingStart="@dimen/space_smd"
            android:paddingTop="@dimen/space_xs"
            android:paddingEnd="@dimen/space_smd"
            android:paddingBottom="@dimen/space_xs"
            android:textAppearance="@style/TextAppearance.Campus.Chip" />

        <TextView
            android:id="@+id/summaryAddressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:textAppearance="@style/TextAppearance.Campus.Body" />

        <TextView
            android:id="@+id/summaryDescriptionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:maxLines="3"
            android:textAppearance="@style/TextAppearance.Campus.Body" />

        <TextView
            android:id="@+id/summaryScoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:textAppearance="@style/TextAppearance.Campus.Title"
            android:textColor="?attr/colorTertiary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/summaryActionButton"
            style="@style/Widget.Campus.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target"
            android:layout_marginTop="@dimen/space_lg"
            android:text="了解详细"
            app:icon="@drawable/ic_chevron_right_24"
            app:iconGravity="textEnd" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
