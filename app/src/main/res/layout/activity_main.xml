<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="112dp">

        <ScrollView
            android:id="@+id/homeSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:id="@+id/welcomeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.Campus.Display" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="今天想看看校园里的哪里？"
                    android:textAppearance="@style/TextAppearance.Campus.Body" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Campus.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:hint="搜索兴趣点"
                    app:startIconDrawable="@drawable/ic_search_24">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/homeSearchInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Campus.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="校区"
                            android:textAppearance="@style/TextAppearance.Campus.Label" />

                        <Spinner
                            android:id="@+id/campusSpinner"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/touch_target"
                            android:layout_marginTop="@dimen/space_xs" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xl"
                    android:text="随机点评"
                    android:textAppearance="@style/TextAppearance.Campus.Title" />

                <TextView
                    android:id="@+id/randomEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/space_lg"
                    android:text="暂无点评，去地图上添加兴趣点并写第一条测评吧"
                    android:textAppearance="@style/TextAppearance.Campus.Body"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/randomReviewRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/listSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:padding="@dimen/space_lg"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="附近兴趣点"
                android:textAppearance="@style/TextAppearance.Campus.Display" />

            <TextView
                android:id="@+id/locationHintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:text="正在获取定位，用于筛选 3 公里内兴趣点"
                android:textAppearance="@style/TextAppearance.Campus.Body" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Campus.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:hint="按名称、地址或类型筛选"
                app:startIconDrawable="@drawable/ic_search_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/listSearchInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <ProgressBar
                android:id="@+id/listProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="@dimen/space_md"
                android:indeterminate="true" />

            <TextView
                android:id="@+id/listEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="@dimen/space_lg"
                android:text="附近暂无兴趣点"
                android:textAppearance="@style/TextAppearance.Campus.Body"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/nearbyPoiRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/space_md"
                android:clipToPadding="false"
                android:layout_weight="1" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/favoriteSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="收藏"
                    android:textAppearance="@style/TextAppearance.Campus.Display" />

                <TextView
                    android:id="@+id/favoriteEmptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/space_lg"
                    android:text="暂无收藏"
                    android:textAppearance="@style/TextAppearance.Campus.Body"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/favoriteRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/mySection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/touch_target"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="我的"
                        android:textAppearance="@style/TextAppearance.Campus.Display" />

                    <ImageButton
                        android:id="@+id/logoutButton"
                        android:layout_width="@dimen/touch_target"
                        android:layout_height="@dimen/touch_target"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="退出登录"
                        android:padding="14dp"
                        android:src="@drawable/ic_logout_24"
                        android:tint="?attr/colorError" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Campus.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/space_lg">

                        <TextView
                            android:id="@+id/userAvatarText"
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:background="@drawable/bg_profile_avatar"
                            android:gravity="center"
                            android:textColor="@color/campus_nav_selected_icon"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_lg"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/userNameText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Campus.Headline" />

                            <TextView
                                android:id="@+id/userAccountText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_xs"
                                android:textAppearance="@style/TextAppearance.Campus.Body" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/favoriteSummaryCard"
                        style="@style/Widget.Campus.Card"
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:contentDescription="查看我的收藏"
                        android:focusable="true"
                        app:rippleColor="?attr/colorPrimaryContainer">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="@dimen/space_md">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_heart_24"
                                android:tint="?attr/colorPrimary" />

                            <TextView
                                android:id="@+id/favoriteCountText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_sm"
                                android:text="0 收藏"
                                android:textAppearance="@style/TextAppearance.Campus.Title" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/reviewSummaryCard"
                        style="@style/Widget.Campus.Card"
                        android:layout_width="0dp"
                        android:layout_height="112dp"
                        android:layout_marginStart="@dimen/space_md"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:contentDescription="查看我发表的测评"
                        android:focusable="true"
                        app:rippleColor="?attr/colorPrimaryContainer">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="@dimen/space_md">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_rate_review_24"
                                android:tint="?attr/colorPrimary" />

                            <TextView
                                android:id="@+id/reviewCountText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_sm"
                                android:text="0 测评"
                                android:textAppearance="@style/TextAppearance.Campus.Title" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:id="@+id/myReviewsSection"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/colorSurface"
            android:orientation="vertical"
            android:padding="@dimen/space_lg"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/myReviewsBackButton"
                    android:layout_width="@dimen/touch_target"
                    android:layout_height="@dimen/touch_target"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="返回我的"
                    android:padding="14dp"
                    android:src="@drawable/ic_arrow_back_24"
                    android:tint="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:text="我的测评"
                    android:textAppearance="@style/TextAppearance.Campus.Headline" />
            </LinearLayout>

            <TextView
                android:id="@+id/myReviewEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="@dimen/space_lg"
                android:text="暂无测评记录"
                android:textAppearance="@style/TextAppearance.Campus.Body"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/myReviewRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/space_md"
                android:clipToPadding="false"
                android:layout_weight="1" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginEnd="@dimen/space_lg"
        android:layout_marginBottom="@dimen/space_lg"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="@dimen/space_sm">

        <ImageButton
            android:id="@+id/homeTab"
            style="@style/Widget.Campus.NavIcon"
            android:contentDescription="主页"
            android:src="@drawable/ic_home_24" />

        <ImageButton
            android:id="@+id/listTab"
            style="@style/Widget.Campus.NavIcon"
            android:contentDescription="列表"
            android:src="@drawable/ic_list_24" />

        <ImageButton
            android:id="@+id/addTab"
            style="@style/Widget.Campus.NavIcon"
            android:contentDescription="新加兴趣点"
            android:src="@drawable/ic_add_24" />

        <ImageButton
            android:id="@+id/favoriteTab"
            style="@style/Widget.Campus.NavIcon"
            android:contentDescription="收藏"
            android:src="@drawable/ic_heart_24" />

        <ImageButton
            android:id="@+id/myTab"
            style="@style/Widget.Campus.NavIcon"
            android:contentDescription="我的"
            android:src="@drawable/ic_user_24" />
    </LinearLayout>
</FrameLayout>
