<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Campus.Card.List"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_smd"
    android:clickable="true"
    android:focusable="true"
    app:rippleColor="?attr/colorPrimaryContainer">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="116dp"
        android:orientation="vertical"
        android:padding="@dimen/space_md">

        <TextView
            android:id="@+id/poiNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Campus.Title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/poiMetaText"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="@drawable/bg_chip_primary"
                android:gravity="center"
                android:minWidth="52dp"
                android:paddingStart="@dimen/space_smd"
                android:paddingEnd="@dimen/space_smd"
                android:textAppearance="@style/TextAppearance.Campus.Chip"
                android:textColor="@color/campus_on_primary_container" />

            <TextView
                android:id="@+id/poiScoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_smd"
                android:textAppearance="@style/TextAppearance.Campus.Chip"
                android:textColor="?attr/colorTertiary" />
        </LinearLayout>

        <TextView
            android:id="@+id/poiAddressText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Campus.Body" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
